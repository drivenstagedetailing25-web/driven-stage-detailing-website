---
import ArrowRight from '@/assets/svg/arrow-right.svg'

interface Props {
  href?: string
}

const { href = '/services' } = Astro.props;
---

<a
  href={href}
  class='primary-btn group inline-flex items-center justify-center gap-3 min-h-[4rem] px-8 py-3 no-underline'
>
  <span class='flex flex-col items-start text-left gap-1 min-w-0'>
    <span class='font-barlow font-semibold text-[clamp(1.1rem,1.7vw,1.9rem)] tracking-wide leading-none whitespace-nowrap'>
      <slot />
    </span>
  </span>
  <span class='primary-btn-arrow inline-flex items-center justify-center flex-shrink-0 w-8 h-8' aria-hidden='true'>
    <ArrowRight class='size-5' />
  </span>
</a>

<style>
  .primary-btn {
    background: var(--color-primary);
    color: var(--color-light);
    clip-path: polygon(3.5% 0, 100% 0, 96.5% 100%, 0 100%);
    box-shadow: 0 4px 15px rgb(0 0 0 / 0.15);
    transition:
      transform 300ms ease,
      filter 300ms ease,
      box-shadow 300ms ease;
  }

  .primary-btn:hover {
    transform: translateY(-2px);
    filter: brightness(1.08);
    box-shadow: 0 8px 25px rgb(0 0 0 / 0.25);
  }

  .primary-btn-arrow {
    transition: transform 300ms ease;
  }

  .primary-btn:hover .primary-btn-arrow {
    transform: translateX(3px);
  }
</style>
