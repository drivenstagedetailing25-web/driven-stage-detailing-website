---
import Phone from '@/assets/svg/phone.svg'
---

<a
  href='tel:201-966-6990'
  class='phone-btn inline-flex items-center justify-center gap-3 min-h-[4rem] px-6 py-4 no-underline'
>
  <span class='phone-btn-icon inline-flex items-center justify-center flex-shrink-0 w-8 h-8' aria-hidden='true'>
    <Phone class='size-5' />
  </span>
  <span class='flex flex-col items-start gap-1 min-w-0 text-left'>
    <span class='font-barlow font-semibold text-[clamp(1.1rem,1.7vw,1.9rem)] tracking-wide leading-none'>(201) 966-6990</span>
    <span class='text-xs font-bold tracking-[0.12em] uppercase opacity-75'>Book Now</span>
  </span>
</a>

<style>
  .phone-btn {
    background: var(--color-primary);
    color: var(--color-light);
    clip-path: polygon(3.5% 0, 100% 0, 96.5% 100%, 0 100%);
    box-shadow: 0 4px 15px rgb(0 0 0 / 0.15);
    transition:
      transform 300ms ease,
      filter 300ms ease,
      box-shadow 300ms ease;
  }

  .phone-btn:hover {
    transform: translateY(-2px);
    filter: brightness(1.08);
    box-shadow: 0 8px 25px rgb(0 0 0 / 0.25);
  }
</style>
