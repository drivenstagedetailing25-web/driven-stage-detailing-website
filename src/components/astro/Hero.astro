---
import Phone from '@/assets/svg/phone.svg'
import ArrowRight from '@/assets/svg/arrow-right.svg'
---

<section
  class='min-h-[100svh] flex items-center justify-center relative overflow-hidden lg:pt-10'
>
  <div class='absolute inset-0 z-0'>
    <video
      autoplay
      muted
      loop
      playsinline
      poster='/videos/fallback.webp'
      class='absolute inset-0 w-full h-full object-cover'
    >
      <source src='/videos/video-bg.webm' type='video/webm' />
      Your browser does not support the video tag.
    </video>

    <div class='absolute inset-0 bg-black/50'></div>
  </div>

  <div class='container mx-auto px-6 text-center relative z-20 pt-10'>
    <h1
      class='hero-title font-bold tracking-wide text-white mb-6 font-barlow flex flex-col items-center'
    >
      <span class='block animate-fade-up animate-delay-200'>
        DRIVEN STAGE MOBILE</span
      >
      <span class='block animate-fade-up animate-delay-500'>
        <span class='text-primary'>LUXURY AUTO</span>
        <span class='text-gradient-primary inline-block max-w-fit mx-auto'
          >DETAILING</span
        >
      </span>
    </h1>

    <p
      class='hero-subtitle mb-8 max-w-2xl mx-auto text-muted font-semibold tracking-wider'
    >
      <span id='typewriter-text'></span><span id='typewriter-cursor'>|</span>
    </p>

    <p
      class='hero-tags mb-8 text-muted font-medium flex flex-wrap justify-center gap-x-3'
    >
      <span>100% Mobile</span>
      <span aria-hidden='true'>·</span>
      <span>We Come To You</span>
      <span aria-hidden='true'>·</span>
      <span>Ceramic Coating</span>
      <span aria-hidden='true'>·</span>
      <span>Paint Correction</span>
      <span aria-hidden='true'>·</span>
      <span>Interior Detailing</span>
      <span aria-hidden='true'>·</span>
      <span>Exterior Detailing</span>
    </p>

    <div class='cta-row' style='animation-delay: 0.4s;'>
      <a href='tel:201-966-6990' class='cta-slab cta-slab-phone'>
        <span class='cta-icon' aria-hidden='true'>
          <Phone class='size-5' />
        </span>

        <span class='flex flex-col items-start gap-2 min-w-0 text-left'>
          <span class='cta-main'>(201) 966-6990</span>
          <span class='cta-meta'>8AM–6PM · Sunday-Friday</span>
        </span>
      </a>

      <a href='/contact' class='cta-slab cta-slab-primary'>
        <span
          class='flex flex-col items-start text-left sm:items-end sm:text-right gap-1 min-w-0'
        >
          <span class='cta-main'>Contact Info</span>
        </span>

        <span class='cta-arrow' aria-hidden='true'>
          <ArrowRight class='size-5' />
        </span>
      </a>
    </div>
  </div>
</section>

<style>
  .cta-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    justify-content: center;
    align-items: center;
  }

  @media (min-width: 640px) {
    .cta-row {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      max-width: 42rem;
      margin-inline: auto;
    }
  }

  .cta-slab {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    min-height: 3.75rem;
    padding: 0.75rem 1rem;
    text-decoration: none;
    transition:
      transform 300ms ease,
      filter 300ms ease,
      box-shadow 300ms ease;
  }

  .cta-slab:hover {
    transform: translateY(-2px);
    filter: brightness(1.03);
  }

  .cta-slab-phone {
    background: rgb(255 255 255 / 0.06);
    color: var(--color-light);
    border: 1px solid rgb(255 255 255 / 0.3);
    clip-path: polygon(3.5% 0, 100% 0, 96.5% 100%, 0 100%);
    box-shadow: inset 0 0 0 1px rgb(255 255 255 / 0.04);
    min-height: 4.5rem;
    padding-block: 1rem;
    transition:
      transform 300ms ease,
      background 300ms ease,
      border-color 300ms ease;
  }

  .cta-slab-phone:hover {
    transform: none;
    background: rgb(255 255 255 / 0.1);
    border-color: rgb(255 255 255 / 0.5);
  }

  .cta-slab-phone:hover .cta-main,
  .cta-slab-phone:hover .cta-meta {
    color: rgb(255 255 255 / 1);
  }

  .cta-slab-primary {
    background: linear-gradient(
      90deg,
      var(--color-primary),
      var(--color-primary-light)
    );
    color: var(--color-dark);
    clip-path: polygon(3.5% 0, 100% 0, 96.5% 100%, 0 100%);
    box-shadow: 0 18px 35px rgb(0 0 0 / 0.2);
  }

  .cta-icon,
  .cta-arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
  }

  .cta-icon {
    width: 2rem;
    height: 2rem;
    color: inherit;
  }

  .cta-arrow {
    width: 2rem;
    height: 2rem;
    color: inherit;
    transition: transform 300ms ease;
  }

  .cta-slab-primary {
    min-height: 4rem;
  }

  .cta-slab-primary:hover .cta-arrow {
    transform: translateX(3px);
  }

  .cta-main {
    font-family: var(--font-barlow);
    font-size: clamp(1.1rem, 1.7vw, 1.9rem);
    font-weight: 600;
    letter-spacing: 0.03em;
    line-height: 1;
    white-space: nowrap;
  }

  .cta-meta {
    font-size: 0.81rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    opacity: 0.76;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .hero-title {
    font-size: clamp(2.25rem, 5vw + 2vh, 5.438rem);
    line-height: 1;
  }

  .hero-subtitle {
    font-size: clamp(1.125rem, 1.5vw + 0.8vh, 1.375rem);
  }

  .hero-tags {
    font-size: clamp(0.7rem, 1vw + 0.4vh, 1rem);
  }

  #typewriter-cursor {
    display: inline-block;
    opacity: 1;
    transition: opacity 0.4s ease;
    animation: blink 0.7s step-end infinite;
  }
  #typewriter-cursor.done {
    opacity: 0;
    animation: none;
  }
  @keyframes blink {
    50% { opacity: 0; }
  }

  @media (max-width: 639px) {
    .cta-slab {
      min-height: 3rem;
      padding: 0.5rem 0.75rem;
      gap: 0.5rem;
    }

    .cta-slab-phone {
      min-height: 3.25rem;
      padding-block: 0.5rem;
    }

    .cta-slab-primary {
      min-height: 3rem;
    }

    .cta-icon,
    .cta-arrow {
      width: 1.25rem;
      height: 1.25rem;
    }

    .cta-arrow {
      display: none;
    }

    .cta-main {
      font-size: 0.95rem;
    }

    .cta-meta {
      font-size: 1rem;
    }

    .cta-main,
    .cta-meta {
      white-space: normal;
    }

    .cta-slab-phone .flex {
      gap: 0.25rem;
    }
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const el = document.getElementById('typewriter-text')
    const cursor = document.getElementById('typewriter-cursor')
    if (!el || !cursor) return

    const text = 'FROM THE ROAD TO THE SPOTLIGHT'
    el.textContent = ''
    cursor.classList.remove('done')

    let i = 0
    function type() {
      if (i < text.length) {
        el.textContent += text.charAt(i)
        i++
        setTimeout(type, 60 + Math.random() * 40)
      } else {
        cursor.classList.add('done')
      }
    }

    setTimeout(type, 800)
  })
</script>
