---
import Layout from '@/layouts/Layout.astro'
import { Image } from 'astro:assets'
import Calendar from '@/assets/svg/calendar.svg'
import Home from '@/assets/svg/home.svg'
import ChevronRight from '@/assets/svg/chevron-right.svg'
import CheckMark from '@/assets/svg/check-mark.svg'
import { OpenContactModalButton } from '@/components/react/OpenContactModalButton'

const paintCorrectionOptions = [
  {
    id: 1,
    title: 'Paint Correction Stage 1',
    price: '$795',
    duration: '6 hours',
    image: '/images/services/paint-correction.jpg',
    alt: 'Paint Correction Stage 1',
    badge: {
      text: 'Single Stage',
      bgColor: 'bg-primary',
    },
    description:
      'Single-step paint correction to remove light swirl marks, minor scratches, and oxidation. Perfect for vehicles with light to moderate paint imperfections using professional-grade compounds and polishing techniques.',
    features: [
      'Advanced Paint Decontamination & Surface Preparation',
      'Professional Clay Bar Treatment',
      'Single-Stage Paint Enhancement Polish',
      'Removes Up to 60–70% of Surface Imperfections',
      'Durable Paint Sealant for Enhanced Shine and Protection',
    ],
    buttonText: 'Schedule Stage 1 Correction',
    borderClass: 'border border-zinc-200',
  },
  {
    id: 2,
    title: 'Paint Correction Stage 2',
    price: '$995',
    duration: '8 hours',
    image: '/images/services/ceramic-coating.jpg',
    alt: 'Paint Correction Stage 2',
    badge: {
      text: 'Multi-Stage',
      bgColor: 'bg-gradient-to-r from-yellow-400 to-orange-500',
      textColor: 'text-dark',
    },
    description:
      'Multi-step paint correction process for heavily damaged paint. Removes deep scratches, severe swirl marks, and restores paint to showroom condition.',
    features: [
      'Advanced Paint Decontamination & Surface Preparation',
      'Premium Clay Bar Treatment',
      'Heavy Defect Removal with Compound Cutting',
      'Refinement Polish for Enhanced Depth and Clarity',
      'Corrects Up to 85–95% of Paint Imperfections',
      'Water Spot Removal Included',
      'Brilliant Showroom Mirror Gloss Finish',
    ],
    buttonText: 'Schedule Stage 2 Correction',
    borderClass: 'border-2 border-primary',
  },
]
---

<Layout 
  title='Paint Correction Service - Driven Stage Detailing'
  description='Expert paint correction services that eliminate swirl marks, scratches, and imperfections. Multi-stage process restores your vehicle to factory-perfect finish with professional techniques and premium products.'
>
  <section class='first-section bg-gradient-secondary'>
    <div
      class='container mx-auto px-6 py-20 grid lg:grid-cols-2 gap-12 lg:gap-16 items-center'
    >
      <div
        class='text-center lg:text-left flex flex-col items-center lg:items-start'
      >
        <!-- Breadcrumb -->
        <nav
          class='flex items-center space-x-2 text-sm mb-10'
          aria-label='Breadcrumb'
        >
          <a
            href='/'
            class='text-foreground hover:text-accent transition-colors duration-200 flex items-center'
          >
            <Home class='size-6 mr-2' />
            Home
          </a>
          <ChevronRight class='size-4 text-dark' />
          <a
            href='/services'
            class='text-foreground hover:text-accent transition-colors duration-200'
          >
            Services
          </a>
          <ChevronRight class='size-4 text-dark' />
          <span class='text-gradient-accent font-medium'>Paint Correction</span>
        </nav>

        <h1
          class='text-4xl md:text-5xl lg:text-6xl font-bold font-barlow text-primary mb-6 leading-tight animate-fade-up'
        >
          Paint <span class='text-gradient-primary'>Correction</span>
        </h1>
        <p class='text-foreground text-lg md:text-xl leading-relaxed mb-8'>
          Restore your vehicle's paint to its original brilliance. Our
          professional paint correction services remove swirl marks, scratches,
          and oxidation using advanced techniques and premium products for a
          flawless finish.
        </p>
        <OpenContactModalButton client:visible>
          Schedule Service
          <Calendar class='ml-2 size-5' />
        </OpenContactModalButton>
      </div>

      <div class='relative overflow-hidden rounded-2xl shadow-2xl'>
        <Image
          width={800}
          height={600}
          src='/images/services/paint-correction.jpg'
          alt='Paint Correction Service'
          class='w-full h-[450px] object-cover'
        />
      </div>
    </div>
  </section>

  <!-- Paint Correction Options Section -->
  <section class='py-20 bg-white'>
    <div class='container mx-auto px-6'>
      <h2
        class='text-3xl md:text-4xl font-bold font-barlow text-center text-gradient-primary mb-4 md:h-12'
      >
        Choose Your Paint Correction Level
      </h2>
      <p class='text-center text-foreground text-lg mb-16 max-w-3xl mx-auto'>
        Select the appropriate paint correction stage based on your vehicle's
        condition. Our expert technicians will assess and recommend the best
        treatment for optimal results.
      </p>

      <div class='grid md:grid-cols-2 gap-8 lg:gap-12 max-w-5xl mx-auto'>
        {
          paintCorrectionOptions.map((service) => (
            <article
              class={`bg-white rounded-2xl hover:-translate-y-1 hover:shadow-xl shadow-md transition-all duration-300 ${service.borderClass} relative animate-fade-up flex flex-col overflow-hidden`}
            >
              <div class='relative w-full h-56 overflow-hidden flex-shrink-0'>
                <Image
                  class='relative w-full h-full object-cover'
                  width={400}
                  height={200}
                  src={service.image}
                  alt={service.alt}
                  loading='lazy'
                />
                <div class='absolute inset-0 bg-gradient-to-t from-black/60 to-black/20' />
                {service.badge && (
                  <div class='absolute top-3 left-3'>
                    <span
                      class={`${service.badge.bgColor} ${service.badge.textColor || 'text-white'} px-3 py-1 rounded-full text-xs font-semibold`}
                    >
                      {service.badge.text}
                    </span>
                  </div>
                )}
              </div>

              <div class='p-5 flex flex-col flex-1'>
                <h3 class='text-xl font-bold font-barlow text-foreground mb-3'>
                  {service.title}
                </h3>
                <div class='flex items-baseline mb-4'>
                  <span class='text-foreground/85'>From</span>
                  <span class='text-2xl font-bold text-gradient-accent ml-2'>
                    {service.price}
                  </span>
                  <span class='text-foreground/85 ml-1'>
                    / {service.duration}
                  </span>
                </div>

                {service.description && (
                  <p class='text-foreground/90 leading-relaxed text-sm mb-3 flex-1'>
                    {service.description}
                  </p>
                )}
                {service.features && (
                  <ul class='space-y-1.5 text-foreground text-sm mb-6 flex-1'>
                    {service.features.map((feature) => (
                      <li class='flex items-start'>
                        <CheckMark class='w-4 h-4 text-accent mr-2 mt-0.5 flex-shrink-0' />
                        <span>{feature}</span>
                      </li>
                    ))}
                  </ul>
                )}

                <OpenContactModalButton client:visible fullWidth>
                  Schedule Service
                  <Calendar class='ml-2 size-5' />
                </OpenContactModalButton>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section
    class='py-20 bg-dark bg-gradient-to-b from-primary/25 via-dark to-dark'
  >
    <div class='container mx-auto px-6 text-center'>
      <h2 class='text-3xl md:text-4xl lg:text-5xl font-bold font-barlow text-white mb-6'>
        Ready to <span class='text-gradient-primary'>Restore</span> Your Paint?
      </h2>
      <p class='text-muted text-lg mb-8 max-w-2xl mx-auto'>
        Transform your vehicle's appearance with our professional paint
        correction services. Book your consultation today for a flawless finish.
      </p>
      <OpenContactModalButton client:visible>
        Schedule Service
        <Calendar class='ml-2 size-5' />
      </OpenContactModalButton>
    </div>
  </section>
</Layout>
