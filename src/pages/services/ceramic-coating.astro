---
import Layout from '../../layouts/Layout.astro'
import { Image } from 'astro:assets'
import Calendar from '../../assets/svg/calendar.svg'
import Home from '../../assets/svg/home.svg'
import ChevronRight from '../../assets/svg/chevron-right.svg'
import CheckMark from '../../assets/svg/check-mark.svg'
import { OpenContactModalButton } from '../../components/react/OpenContactModalButton'

const ceramicCoatingOptions = [
  {
    id: 1,
    title: 'Ceramic Coating Stage 1',
    price: '$1095',
    duration: '8 hours',
    image: '/images/services/ceramic-coating.jpg',
    alt: 'Ceramic Coating Stage 1',
    badge: {
      text: 'Standard Protection',
      bgColor: 'bg-primary',
    },
    features: [
      'Advanced Paint Decontamination & Surface Preparation',
      'Premium Clay Bar Treatment',
      'One-Step Paint Enhancement Polish',
      'Corrects Up to 60–70% of Surface Imperfections',
      'Cerakote Professional Ceramic Coating Installation (Industry leading – 500 washes)',
      '5-Year Manufacturer-Backed Warranty',
      'Extreme Hydrophobic Protection with Brilliant Gloss Finish',
    ],
    buttonText: 'Schedule Stage 1 Coating',
    borderClass: 'border border-zinc-200',
  },
  {
    id: 2,
    title: 'Ceramic Coating Stage 2',
    price: '$1395',
    duration: '9 hours',
    image: '/images/services/paint-correction.jpg',
    alt: 'Ceramic Coating Stage 2',
    badge: {
      text: 'Premium Protection',
      bgColor: 'bg-gradient-to-r from-yellow-400 to-orange-500',
      textColor: 'text-dark',
    },
    features: [
      'Advanced Paint Decontamination & Surface Preparation',
      'Premium Clay Bar Treatment',
      'Two-Step Paint Enhancement Polish (Heavy Defect Removal with Compound Followed by Fine Polishing)',
      'Up to 85–95% Paint Imperfection Correction',
      'Cerakote Professional Ceramic Coating Installation (Industry leading – 500 washes)',
      '5-Year Manufacturer-Backed Warranty',
      'Extreme Hydrophobic Protection with Brilliant Gloss Finish',
    ],
    buttonText: 'Schedule Stage 2 Coating',
    borderClass: 'border-2 border-primary',
  },
]
---

<Layout
  title='Ceramic Coating Service - Driven Stage Detailing'
  description='Advanced ceramic coating protection with nanotechnology. Creates invisible armor for your vehicle, enhancing shine, durability, and protection against environmental damage. Professional application guaranteed.'
>
  <section class='first-section bg-gradient-secondary'>
    <div
      class='container mx-auto px-6 py-20 grid lg:grid-cols-2 gap-12 lg:gap-16 items-center'
    >
      <div
        class='text-center lg:text-left flex flex-col items-center lg:items-start'
      >
        <!-- Breadcrumb -->
        <nav
          class='flex items-center space-x-2 text-sm mb-10'
          aria-label='Breadcrumb'
        >
          <a
            href='/'
            class='text-foreground hover:text-accent transition-colors duration-200 flex items-center'
          >
            <Home class='size-6 mr-2' />
            Home
          </a>
          <ChevronRight class='size-4 text-dark' />
          <a
            href='/services'
            class='text-foreground hover:text-accent transition-colors duration-200'
          >
            Services
          </a>
          <ChevronRight class='size-4 text-dark' />
          <span class='text-gradient-accent font-medium'>Ceramic Coating</span>
        </nav>

        <h1
          class='text-4xl md:text-5xl lg:text-6xl font-bold font-barlow text-primary mb-6 leading-tight animate-fade-up'
        >
          Ceramic <span class='text-gradient-primary'>Coating</span>
        </h1>
        <p class='text-foreground text-lg md:text-xl leading-relaxed mb-8'>
          Protect your vehicle's paint with our professional ceramic coating
          services. Advanced nanotechnology provides long-lasting protection,
          enhanced gloss, and hydrophobic properties for years of superior paint
          preservation.
        </p>
        <OpenContactModalButton client:visible>
          Schedule Service
          <Calendar class='ml-2 size-5' />
        </OpenContactModalButton>
      </div>

      <div class='relative overflow-hidden rounded-2xl shadow-2xl'>
        <Image
          width={800}
          height={600}
          src='/images/services/ceramic-coating.jpg'
          alt='Ceramic Coating Service'
          class='w-full h-[450px] object-cover'
        />
      </div>
    </div>
  </section>

  <!-- Ceramic Coating Options Section -->
  <section class='py-20 bg-white'>
    <div class='container mx-auto px-6'>
      <h2
        class='text-3xl md:text-4xl font-bold font-barlow text-center text-gradient-primary mb-4 md:h-12'
      >
        Choose Your Protection Level
      </h2>
      <p class='text-center text-foreground text-lg mb-16 max-w-3xl mx-auto'>
        Select the ceramic coating package that best suits your vehicle's needs
        and your protection requirements. All packages include professional
        application and warranty coverage.
      </p>

      <div class='grid lg:grid-cols-2 gap-8 max-w-5xl mx-auto'>
        {
          ceramicCoatingOptions.map((service) => (
            <article
              class={`bg-white rounded-2xl hover:-translate-y-1 hover:shadow-xl transition-all duration-300 ${service.borderClass} relative animate-fade-up flex flex-col overflow-hidden`}
            >
              <div class='relative w-full h-52 overflow-hidden flex-shrink-0'>
                <Image
                  class='w-full h-full object-cover'
                  width={500}
                  height={300}
                  src={service.image}
                  alt={service.alt}
                  loading='lazy'
                />
                <div class='absolute inset-0 bg-gradient-to-t from-black/60 to-black/20' />
              </div>

              <div class='p-5 flex flex-col flex-1'>
                <h3 class='text-xl font-bold font-barlow text-foreground mb-3'>
                  {service.title}
                </h3>
                <div class='flex items-baseline mb-4'>
                  <span class='text-foreground/85'>From</span>
                  <span class='text-2xl font-bold text-gradient-accent ml-2'>
                    {service.price}
                  </span>
                  <span class='text-foreground/85 ml-1'>
                    / {service.duration}
                  </span>
                </div>

                <ul class='space-y-1.5 text-foreground text-sm mb-6 flex-1'>
                  {service.features.map((feature) => (
                    <li class='flex items-start'>
                      <CheckMark class='w-4 h-4 text-accent mr-2 mt-0.5 flex-shrink-0' />
                      <span>{feature}</span>
                    </li>
                  ))}
                </ul>

                <OpenContactModalButton client:visible fullWidth>
                  Schedule Service
                  <Calendar class='ml-2 size-5' />
                </OpenContactModalButton>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section
    class='py-20 bg-dark bg-gradient-to-b from-primary/25 via-dark to-dark'
  >
    <div class='container mx-auto px-6 text-center'>
      <h2 class='text-3xl md:text-4xl font-bold font-barlow text-white mb-6'>
        Ready to <span class='text-gradient-primary'>Protect</span> Your Investment?
      </h2>
      <p class='text-muted text-lg mb-8 max-w-2xl mx-auto'>
        Secure your vehicle's paint with our professional ceramic coating
        services. Contact us today for a consultation and protect your
        investment for years to come.
      </p>
      <OpenContactModalButton client:visible>
        Schedule Service
        <Calendar class='ml-2 size-5' />
      </OpenContactModalButton>
    </div>
  </section>
</Layout>
