---
import { ContactForm } from '@/components/react/ContactForm'
import Layout from '@/layouts/Layout.astro'
import { Image } from 'astro:assets'
import Hero from '@/components/astro/Hero.astro'
import PackageCard from '@/components/astro/PackageCard.astro'
import PrimaryButton from '@/components/astro/PrimaryButton.astro'
import PhoneButton from '@/components/astro/PhoneButton.astro'
import { BackgroundRippleEffect } from '@/components/react/ui/background-ripple-effect'

const essentialPackages = [
  {
    title: 'Essential Stage Exterior',
    preselectSlugs: ['essential-stage-exterior'],
    price: '$110',
    duration: '1 hour',
    image: '/images/services/premium-exterior.jpg',
    alt: 'Essential Stage Exterior Detail',
    badge: { text: 'Exterior Only', bgColor: 'bg-primary' },
    features: [
      'Premium hand wash & dry',
      'Wheel & tire cleaning',
      'Paint Sealant',
      'Wax protection',
      'Exterior glass and mirror cleaning',
    ],
    borderClass: 'border border-neutral-200',
  },
  {
    title: 'Essential Stage Interior',
    preselectSlugs: ['essential-stage-interior'],
    price: '$190',
    duration: '1 hr 30 min',
    image: '/images/services/car-detailing.jpg',
    alt: 'Essential Stage Interior Detail',
    badge: { text: 'Interior Only', bgColor: 'bg-secondary' },
    features: [
      'Complete vacuuming (seats, carpets, trunk)',
      'Dashboard & console cleaning',
      'Door Panels & Cup Holder Areas',
      'Interior glass and mirror cleaning',
      'Air freshening treatment',
    ],
    borderClass: 'border border-neutral-200',
  },
  {
    title: 'Essential Stage Full Detail',
    preselectSlugs: ['essential-stage-full-detail'],
    price: '$240',
    duration: '2 hr 30 min',
    image: '/images/services/paint-correction.jpg',
    alt: 'Essential Stage Full Detail',
    badge: {
      text: 'Complete Package',
      bgColor: 'bg-yellow-400',
      textColor: 'text-dark',
    },
    popularBadge: { text: 'Most Popular', bgColor: 'bg-primary' },
    features: [
      'Full Essential Stage Exterior Services',
      'Full Essential Stage Interior Services',
      'Premium Paint Sealant',
      'The Perfect Balance of Quality and Value',
    ],
    borderClass: 'border-2 border-primary',
  },
]

const luxuryPackages = [
  {
    title: 'Prestige Stage Exterior',
    preselectSlugs: ['prestige-stage-exterior'],
    price: '$160',
    duration: '2 hr',
    image: '/images/services/ceramic-coating.jpg',
    alt: 'Prestige Stage Exterior Detail',
    badge: {
      text: 'Exterior Only',
      bgColor: 'bg-gradient-to-r from-yellow-400 to-orange-500',
      textColor: 'text-dark',
    },
    features: [
      'Everything Included in the Essential Stage Exterior',
      'Enhanced Paint Decontamination for a Smoother Finish',
      'Black Trim Restoration with UV Protection',
      'Thorough Wheel Well Cleaning',
      'Meticulous Attention to Door Jambs and Body Edges',
    ],
    borderClass: 'border border-neutral-200',
  },
  {
    title: 'Prestige Stage Interior',
    preselectSlugs: ['prestige-stage-interior'],
    price: '$390',
    duration: '4 hr 30 min',
    image: '/images/services/car-detailing.jpg',
    alt: 'Prestige Stage Interior Detail',
    badge: {
      text: 'Interior Only',
      bgColor: 'bg-gradient-to-r from-purple-500 to-blue-600',
    },
    features: [
      'Everything Included in the Essential Stage Interior Package',
      'Deep Steam Cleaning of Interior Panels and Vents',
      'Thorough Carpet Shampoo & Extraction',
      'Deep Seat Cleaning with Shampoo & Extraction',
      'Leather Conditioning Treatment',
    ],
    borderClass: 'border border-neutral-200',
  },
  {
    title: 'Prestige Stage Full Detail',
    preselectSlugs: ['prestige-stage-full-detail'],
    price: '$495',
    duration: '6 hours',
    image: '/images/services/paint-correction.jpg',
    alt: 'Prestige Stage Full Detail',
    badge: {
      text: 'Ultimate Package',
      bgColor: 'bg-gradient-to-r from-yellow-400 via-orange-500 to-red-500',
      textColor: 'text-dark',
    },
    features: [
      'Includes Full Prestige Stage Interior Services',
      'Includes Full Prestige Stage Exterior Services',
      'Complete Steam Cleaning & Shampoo Extraction',
      'Premium Leather Conditioning',
      'Trim Restoration & Wheel Well Detailing',
    ],
    savings: 'Save $60!',
    borderClass: 'border-2 border-yellow-400',
  },
]
---

<Layout
  title='Driven Stage Detailing - Professional Mobile Auto Detailing Services'
  description='Professional mobile auto detailing services at your location. Premium paint correction, ceramic coating, and detailing with state-of-the-art equipment and certified technicians.'
>
  <Hero />

  <!-- Services Preview Section -->
  <section id='services' class='py-20 bg-white relative overflow-hidden'>
    <BackgroundRippleEffect rows={7} cols={30} cellSize={48} />
    <div class='container mx-auto px-6 relative z-10'>
      <h2
        class='text-5xl md:text-6xl lg:text-7xl xl:text-[80px] font-bold text-center font-barlow mb-4 text-gray-900'
      >
        Choose Your <span
          class='inline-block intersect:animate-fade-in-left intersect-once'
        >
          <span class='text-primary'>Detail</span>{' '}
          <span class='text-gradient-primary'>Package</span>
        </span>
      </h2>
      <p
        class='text-center text-lg md:text-xl text-gray-600 max-w-2xl mx-auto mb-16'
      >
        Honest, transparent upfront pricing on every package. No hidden fees. We
        come to your home or office.
      </p>
      <h2
        class='text-4xl md:text-5xl font-bold text-center font-barlow text-gray-900'
      >
        Our Detail Services
      </h2>
      <span
        class='mt-3 mb-16 block h-1.5 w-20 rounded-full bg-accent mx-auto overflow-hidden max-w-0 intersect:max-w-20 intersect-once transition-all duration-700 ease-out'
      ></span>

      <div class='flex items-center gap-4 mb-8'>
        <span
          class='h-px flex-1 bg-gradient-to-r from-transparent to-primary/30'
        ></span>
        <span
          class='text-sm font-bold font-barlow text-primary tracking-[0.25em] uppercase'
          >Essential Packages</span
        >
        <span
          class='h-px flex-1 bg-gradient-to-l from-transparent to-primary/30'
        ></span>
      </div>

      <div class='grid md:grid-cols-2 lg:grid-cols-3 gap-8 mb-20'>
        {essentialPackages.map((pkg) => <PackageCard {...pkg} />)}
      </div>

      <div class='flex items-center gap-4 mb-8'>
        <span
          class='h-px flex-1 bg-gradient-to-r from-transparent to-amber-400/40'
        ></span>
        <span
          class='text-sm font-bold font-barlow text-amber-500 tracking-[0.25em] uppercase'
          >Luxury Packages</span
        >
        <span
          class='h-px flex-1 bg-gradient-to-l from-transparent to-amber-400/40'
        ></span>
      </div>

      <div class='grid md:grid-cols-2 lg:grid-cols-3 gap-8'>
        {luxuryPackages.map((pkg) => <PackageCard {...pkg} luxury />)}
      </div>

      <div class='flex justify-center mt-16'>
        <PrimaryButton href='/services'>View All Services</PrimaryButton>
      </div>
    </div>
  </section>

  <!-- Why Choose Us Section -->
  <section class='py-20 bg-muted-blue'>
    <div class='container mx-auto px-6'>
      <h2
        class='text-4xl md:text-5xl font-bold text-center font-barlow text-primary mb-16'
      >
        Why <span class='text-gradient-primary'>Choose Us?</span>
      </h2>

      <div class='space-y-16'>
        <div class='grid lg:grid-cols-2 gap-12 lg:gap-16 items-center'>
          <div class='lg:pl-8'>
            <h3 class='text-3xl font-bold mb-6 font-barlow'>
              Mobile Service at Your Location
            </h3>
            <p class='text-foreground mb-6 leading-relaxed text-lg'>
              We bring our professional service directly to your location. Our
              fully equipped mobile van features state-of-the-art technology,
              and all the premium products needed. No need to leave your home or
              office - we handle everything on-site for your convenience.
            </p>
            <PhoneButton />
          </div>

          <div
            class='relative overflow-hidden rounded-2xl invisible intersect:visible intersect:animate-fade-left intersect-once intersect-full'
          >
            <Image
              width={600}
              height={400}
              src='/images/features/mobile-detailing-trailer.jpg'
              alt='Mobile Detailing Trailer'
              class='w-full h-[400px] object-cover'
            />
          </div>
        </div>

        <!-- Trained Experts -->
        <div class='grid lg:grid-cols-2 gap-12 lg:gap-16 items-center'>
          <div
            class='order-2 lg:order-1 relative overflow-hidden rounded-2xl invisible intersect:visible intersect:animate-fade-right intersect-once intersect-full'
          >
            <Image
              width={600}
              height={400}
              src='/images/features/profesional-technicians.jpg'
              alt='Trained Experts at Work'
              class='w-full h-[400px] object-cover'
            />
          </div>

          <div class='order-1 lg:order-2 lg:pr-8'>
            <h3 class='text-3xl font-bold mb-6 font-barlow'>
              Certified Specialists
            </h3>
            <p class='text-foreground mb-6 leading-relaxed text-lg'>
              Our team consists of highly trained and certified technicians in
              every service area. Each team member receives continuous training
              in the latest detailing techniques, paint correction methods, and
              ceramic coating applications. Your vehicle will be in expert hands
              who understand the specific needs of every surface and material.
            </p>
          </div>
        </div>

        <!-- Quality & Excellence -->
        <div class='grid lg:grid-cols-2 gap-12 lg:gap-16 items-center'>
          <div
            class='order-2 relative overflow-hidden rounded-2xl invisible intersect:visible intersect:animate-fade-left intersect-once intersect-full'
          >
            <Image
              width={600}
              height={400}
              src='/images/features/car-washing.jpg'
              alt='Quality & Excellence in Service'
              class='w-full h-[400px] object-cover'
            />
          </div>

          <div class='order-1 lg:order-1 lg:pl-8'>
            <h3 class='text-3xl font-bold mb-6 font-barlow'>
              Quality & Excellence
            </h3>
            <p class='text-foreground mb-6 leading-relaxed text-lg'>
              We implement the highest quality standards in every service. We
              use only premium products from world-renowned brands, follow
              strict cleaning protocols, and apply proven techniques that
              guarantee exceptional results. Every vehicle receives the same
              careful attention to detail, regardless of make or model.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Section with Car Animation -->
  <section class='relative py-20 bg-dark overflow-hidden'>
    <!-- Animated Car Background -->
    <div id='car-animation' class='absolute inset-0 opacity-30'>
      <div
        id='contact'
        class='absolute right-[3%] top-[45%] -translate-y-1/2 w-full h-full'
      >
        <Image
          width={1200}
          height={800}
          src='/images/yellow-sport-car.webp'
          alt='Car approaching'
          class='w-full h-full object-cover object-center car-filter'
        />
        <div
          class='absolute inset-0 bg-gradient-to-l from-transparent via-dark/50 to-dark'
        >
        </div>
      </div>
    </div>

    <!-- Contact Form Container -->
    <div class='container mx-auto px-6 relative z-10 h-full flex items-center'>
      <div
        class='flex flex-col lg:flex-row items-center lg:justify-around w-full min-h-[100svh]'
      >
        <!-- Left Side - Giant Title -->
        <div
          class='flex flex-col text-center lg:text-left pt-2 justify-center h-full'
        >
          <h2
            id='giant-title'
            class='text-6xl md:text-7xl lg:text-8xl xl:text-9xl font-bold font-barlow text-white leading-none'
          >
            Get Your
            <span class='text-gradient-primary block'>Free Quote</span>
          </h2>
          <p
            id='subtitle'
            class='text-muted text-xl md:text-2xl mt-10 lg:mt-14 max-w-2xl invisible intersect:visible intersect:animate-fade-up intersect-half'
          >
            Ready to transform your vehicle with professional detailing?
          </p>
        </div>

        <!-- Contact Form - Right Side -->
        <article
          class='flex flex-col justify-center h-full w-full max-w-3xl lg:max-w-md xl:max-w-[550px] mt-10 lg:mt-0'
        >
          <ContactForm client:visible blurredBackground />
        </article>
      </div>
    </div>
  </section>
</Layout>

<style>
  .car-filter {
    filter: drop-shadow(1px 1px 10px white);
  }
</style>

<script>
  import { gsap } from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'

  gsap.registerPlugin(ScrollTrigger)

  document.addEventListener('astro:page-load', function () {
    const carElement = document.getElementById('car-animation')
    const contactSection = document.querySelector('section:last-of-type')

    if (!carElement || !contactSection) return

    gsap.fromTo(
      carElement,
      { x: '100%', scale: 0.7 },
      {
        x: '0%',
        scale: 1,
        ease: 'power1.out',
        scrollTrigger: {
          trigger: contactSection,
          start: 'top bottom',
          end: 'bottom bottom',
          scrub: 1,
        },
      },
    )
  })
</script>
